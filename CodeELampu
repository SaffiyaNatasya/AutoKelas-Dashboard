body {
  font-family: Arial, sans-serif;
  background: #f4f6f8;
  text-align: center;
}

h1 {
  margin-top: 20px;
}

.card {
  background: white;
  padding: 20px;
  margin: 20px auto;
  width: 320px;
  border-radius: 10px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

button {
  width: 120px;
  padding: 10px;
  margin: 5px;
  font-size: 16px;
  cursor: pointer;
}
